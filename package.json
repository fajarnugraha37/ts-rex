{
  "name": "@fajarnugraha37/ts-rex-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "test": "bun test",
    "lint": "eslint .",
    "release": "changeset publish",
    "tag": "changeset tag",
    "build": "bun --filter '*' build",
    "core": "bun --filter '@fajarnugraha37/ts-rex'",
    "plugin": "bun --filter '@fajarnugraha37/ts-rex-plugin'",
    "docs": "bun --filter '@fajarnugraha37/ts-rex-docs'"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.3"
  }
}