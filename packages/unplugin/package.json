{
  "name": "@fajarnugraha37/ts-rex-plugin",
  "version": "0.1.0",
  "description": "Ahead-of-Time compilation plugin for TS-Rex",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "bunx tsup --watch",
    "build": "bun run lint && bunx tsc --noEmit && rm -rf dist && bunx tsc && bunx tsup",
    "test": "bun test --isolate",
    "lint": "eslint ."
  },
  "dependencies": {
    "unplugin": "^3.0.0",
    "magic-string": "^0.30.21"
  },
  "peerDependencies": {
    "@fajarnugraha37/ts-rex": "workspace:*"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.3",
    "@rollup/pluginutils": "^5.3.0",
    "acorn": "^8.16.0",
    "esbuild": "^0.28.0",
    "estree-walker": "^3.0.3",
    "rollup": "^4.60.3",
    "vite": "^8.0.12",
    "webpack": "^5.106.2"
  }
}