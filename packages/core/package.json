{
  "name": "@fajarnugraha37/ts-rex",
  "version": "2.0.0",
  "description": "A TypeScript library for building Regex patterns.",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": [
    "./src/syntax/*.ts",
    "./src/index.ts"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "regex",
    "builder",
    "fluent-api",
    "typescript",
    "meta-programming"
  ],
  "author": {
    "name": "Fajar Abdi Nugraha",
    "email": "nugrahafajar37@gmail.com",
    "url": "https://nugrahafajar.my.id"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fajarnugraha37/ts-rex.git"
  },
  "homepage": "https://ts-rex.nugrahafajar.my.id/",
  "license": "MIT",
  "scripts": {
    "dev": "bunx tsup --watch",
    "build": "bun run lint && bunx tsc --noEmit && rm -rf dist && bunx tsc && bunx tsup",
    "test": "bun test --isolate",
    "lint": "eslint ."
  },
  "devDependencies": {
    "expect-type": "^1.3.0",
    "mitata": "^1.0.34"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}